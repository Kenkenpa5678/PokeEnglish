// --- クイズコンポーネント ---

function QuizView({ setView }) {
  const [step, setStep] = useState('setup'); // 'setup', 'playing', 'result'
  const [quizType, setQuizType] = useState('mix'); // 'vocab', 'phrase', 'mix'
  const [quizFormat, setQuizFormat] = useState('en-jp'); // 'en-jp', 'jp-en', 'fill-in'
  
  const [questions, setQuestions] = useState([]);
  const [currentIndex, setCurrentIndex] = useState(0);
  const [score, setScore] = useState(0);
  const [selectedAnswer, setSelectedAnswer] = useState(null);
  const [isCorrect, setIsCorrect] = useState(null);
  const [quizHistory, setQuizHistory] = useState([]);

  const startQuiz = () => {
    let sourceData = [];
    if (quizType === 'vocab' || quizFormat === 'fill-in') {
      sourceData = vocabularyData.map(item => ({...item, type: 'vocab'}));
    } else if (quizType === 'phrase') {
      sourceData = phraseData.map(item => ({...item, type: 'phrase'}));
    } else {
      sourceData = [...vocabularyData.map(item => ({...item, type: 'vocab'})), ...phraseData.map(item => ({...item, type: 'phrase'}))];
    }

    const shuffled = [...sourceData].sort(() => 0.5 - Math.random());
    const maxQ = Math.min(10, shuffled.length);
    const selected = shuffled.slice(0, maxQ);

    const quizQuestions = selected.map(item => {
      let questionNode = null;
      let questionStr = "";
      let answerText = "";
      let wrongOptionsSource = [];

      if (quizFormat === 'fill-in') {
        // --- 穴埋め問題（TOEIC Part-5形式）の生成 ---
        const enStr = item.en.split(' (')[0]; // カッコなどを除去して基本単語を抽出
        const escapedEn = enStr.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        
        // 複数形なども考慮した正規表現の構築 (berry -> berries, ball -> balls など)
        let regexStr = escapedEn;
        if (escapedEn.toLowerCase().endsWith('y')) {
            regexStr = `${escapedEn.slice(0, -1)}(y|ies)`;
        } else {
            regexStr = `${escapedEn}(s|es)?`;
        }
        const regex = new RegExp(`\\b${regexStr}\\b`, 'i');
        
        let blankedExample = item.example;
        if (regex.test(item.example)) {
            blankedExample = item.example.replace(regex, '________');
        } else {
            // 見つからなかった場合のフォールバック（前方一致）
            const firstWord = enStr.split(' ')[0];
            const fwRegex = new RegExp(`\\b${firstWord.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}(s|es|ies)?\\b`, 'i');
            if (fwRegex.test(item.example)) {
               blankedExample = item.example.replace(fwRegex, '________');
            } else {
               blankedExample = `[        ] ${item.example}`; 
            }
        }

        questionNode = (
          <div className="flex flex-col h-full justify-center">
            <p className="text-xl mb-4 text-gray-800 leading-snug">{blankedExample}</p>
            <p className="text-xs text-gray-400 font-normal">ヒント (意味): {item.jp}</p>
          </div>
        );
        questionStr = blankedExample;
        answerText = item.en;
        
        // ダミー選択肢はできるだけ同じカテゴリから抽出（品詞が似ている確率が高いため）
        wrongOptionsSource = sourceData.filter(opt => opt.category === item.category && opt.id !== item.id).map(opt => opt.en);
        if (wrongOptionsSource.length < 3) {
            const others = sourceData.filter(opt => opt.id !== item.id && opt.category !== item.category).map(opt => opt.en);
            wrongOptionsSource = [...wrongOptionsSource, ...others];
        }
      } else {
        // --- 通常の英和・和英問題 ---
        questionStr = quizFormat === 'en-jp' ? item.en : item.jp;
        answerText = quizFormat === 'en-jp' ? item.jp : item.en;
        wrongOptionsSource = sourceData
          .filter(opt => opt.id !== item.id || opt.type !== item.type)
          .map(opt => quizFormat === 'en-jp' ? opt.jp : opt.en);
      }

      const wrongOptions = wrongOptionsSource.sort(() => 0.5 - Math.random()).slice(0, 3);
      const options = [...wrongOptions, answerText].sort(() => 0.5 - Math.random());

      return {
        questionStr: questionStr, // 履歴用文字列
        questionNode: questionNode, // 画面描画用ノード (nullなら文字列を表示)
        answer: answerText,
        options: options,
        type: item.type
      };
    });

    setQuestions(quizQuestions);
    setStep('playing');
    setCurrentIndex(0);
    setScore(0);
    setSelectedAnswer(null);
    setIsCorrect(null);
    setQuizHistory([]);
  };

  const handleAnswer = (option) => {
    if (selectedAnswer) return;

    setSelectedAnswer(option);
    const correct = option === questions[currentIndex].answer;
    setIsCorrect(correct);
    
    if (correct) setScore(score + 1);

    setQuizHistory(prev => [...prev, {
      question: questions[currentIndex].questionStr,
      answer: questions[currentIndex].answer,
      userAnswer: option,
      isCorrect: correct
    }]);

    setTimeout(() => {
      if (currentIndex + 1 < questions.length) {
        setCurrentIndex(currentIndex + 1);
        setSelectedAnswer(null);
        setIsCorrect(null);
      } else {
        setStep('result');
      }
    }, 1500);
  };

  if (step === 'setup') {
    return (
      <div className="flex-1 flex flex-col p-6 bg-slate-50">
        <div className="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex-1">
          <div className="flex items-center gap-2 mb-6 border-b pb-4">
            <Settings className="text-gray-400" />
            <h2 className="text-xl font-bold text-gray-800">テスト設定 (全10問)</h2>
          </div>
          
          <div className="space-y-8">
            <div>
              <h3 className="text-sm font-bold text-gray-500 mb-3">出題形式</h3>
              <div className="grid grid-cols-1 sm:grid-cols-3 gap-2">
                <button onClick={() => setQuizFormat('en-jp')} className={`p-3 rounded-xl text-sm font-bold border-2 transition-all ${quizFormat === 'en-jp' ? 'bg-indigo-50 border-indigo-500 text-indigo-700 shadow-sm' : 'border-gray-100 text-gray-500 hover:bg-gray-50'}`}>英語 → 日本語</button>
                <button onClick={() => setQuizFormat('jp-en')} className={`p-3 rounded-xl text-sm font-bold border-2 transition-all ${quizFormat === 'jp-en' ? 'bg-indigo-50 border-indigo-500 text-indigo-700 shadow-sm' : 'border-gray-100 text-gray-500 hover:bg-gray-50'}`}>日本語 → 英語</button>
                <button 
                  onClick={() => { setQuizFormat('fill-in'); setQuizType('vocab'); }} 
                  className={`p-3 rounded-xl text-sm font-bold border-2 transition-all ${quizFormat === 'fill-in' ? 'bg-indigo-50 border-indigo-500 text-indigo-700 shadow-sm' : 'border-gray-100 text-gray-500 hover:bg-gray-50'}`}
                >
                  穴埋め (Part5風)
                </button>
              </div>
            </div>

            <div className={quizFormat === 'fill-in' ? 'opacity-50' : ''}>
              <h3 className="text-sm font-bold text-gray-500 mb-3 flex items-center justify-between">
                出題範囲
                {quizFormat === 'fill-in' && <span className="text-xs text-rose-500 font-normal">※穴埋めは単語のみ対応</span>}
              </h3>
              <div className="grid grid-cols-3 gap-2">
                <button onClick={() => setQuizType('vocab')} className={`p-3 rounded-xl text-sm font-bold border-2 transition-all ${quizType === 'vocab' ? 'bg-blue-50 border-blue-500 text-blue-700' : 'border-gray-100 text-gray-500 hover:bg-gray-50'}`}>単語のみ</button>
                <button disabled={quizFormat === 'fill-in'} onClick={() => setQuizType('phrase')} className={`p-3 rounded-xl text-sm font-bold border-2 transition-all ${quizType === 'phrase' ? 'bg-blue-50 border-blue-500 text-blue-700' : 'border-gray-100 text-gray-500 hover:bg-gray-50'} ${quizFormat === 'fill-in' ? 'cursor-not-allowed' : ''}`}>フレーズのみ</button>
                <button disabled={quizFormat === 'fill-in'} onClick={() => setQuizType('mix')} className={`p-3 rounded-xl text-sm font-bold border-2 transition-all ${quizType === 'mix' ? 'bg-blue-50 border-blue-500 text-blue-700' : 'border-gray-100 text-gray-500 hover:bg-gray-50'} ${quizFormat === 'fill-in' ? 'cursor-not-allowed' : ''}`}>すべて</button>
              </div>
            </div>
          </div>
        </div>

        <button 
          onClick={startQuiz}
          className="mt-6 w-full flex items-center justify-center gap-2 bg-rose-500 text-white p-4 rounded-xl font-bold text-lg hover:bg-rose-600 transition-colors shadow-md transform hover:scale-[1.02] active:scale-[0.98]"
        >
          <Play size={24} fill="currentColor" />
          テストスタート！
        </button>
      </div>
    );
  }

  if (step === 'result') {
    return (
      <div className="flex-1 flex flex-col items-center p-6 bg-slate-50 h-full overflow-hidden">
        <div className="flex flex-col items-center shrink-0">
          <Trophy size={64} className="text-yellow-400 mb-2" />
          <h2 className="text-2xl font-bold text-gray-800 mb-1">結果発表！</h2>
          <p className="text-4xl font-extrabold text-blue-600 mb-4">
            {score} / {questions.length} <span className="text-xl text-gray-500 font-normal">正解</span>
          </p>
        </div>
        
        <div className="w-full max-w-sm flex-1 overflow-y-auto mb-4 border-t border-b border-gray-200 py-4">
          <h3 className="font-bold text-gray-700 mb-3 flex items-center gap-2">
            <BookOpen size={18} />
            テスト結果の振り返り
          </h3>
          <div className="space-y-3">
            {quizHistory.map((item, i) => (
              <div key={i} className={`p-3 rounded-xl border ${item.isCorrect ? 'bg-emerald-50 border-emerald-200' : 'bg-rose-50 border-rose-200'}`}>
                <p className="font-bold text-sm text-gray-800 mb-2">Q{i + 1}. {item.question}</p>
                {item.isCorrect ? (
                  <p className="text-emerald-600 text-xs font-bold flex items-center gap-1"><CheckCircle2 size={14}/> 正解: {item.answer}</p>
                ) : (
                  <div className="space-y-1">
                    <p className="text-rose-600 text-xs font-bold flex items-center gap-1"><XCircle size={14}/> あなたの回答: {item.userAnswer}</p>
                    <p className="text-emerald-600 text-xs font-bold flex items-center gap-1"><CheckCircle2 size={14}/> 正解: {item.answer}</p>
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
        
        <div className="w-full max-w-sm space-y-3 shrink-0">
          <button onClick={() => setStep('setup')} className="w-full flex items-center justify-center gap-2 bg-blue-600 text-white p-3 rounded-xl font-bold hover:bg-blue-700 transition-colors">
            <Settings size={20} /> 設定を変えてもう一度
          </button>
          <button onClick={startQuiz} className="w-full flex items-center justify-center gap-2 bg-rose-100 text-rose-600 border-2 border-rose-200 p-3 rounded-xl font-bold hover:bg-rose-200 transition-colors">
            <RefreshCw size={20} /> 同じ設定でリトライ
          </button>
          <button onClick={() => setView('home')} className="w-full flex items-center justify-center gap-2 bg-white text-gray-700 border-2 border-gray-200 p-3 rounded-xl font-bold hover:bg-gray-50 transition-colors">
            <ArrowLeft size={20} /> ホームに戻る
          </button>
        </div>
      </div>
    );
  }

  const currentQ = questions[currentIndex];

  return (
    <div className="flex-1 flex flex-col bg-slate-50 p-6 relative">
      <div className="w-full bg-gray-200 rounded-full h-2 mb-6">
        <div className="bg-blue-600 h-2 rounded-full transition-all duration-300" style={{ width: `${((currentIndex) / questions.length) * 100}%` }}></div>
      </div>

      <div className="text-sm text-gray-500 font-bold mb-2">
        Question {currentIndex + 1} of {questions.length}
      </div>

      <div className="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 mb-8 min-h-[160px] flex items-center justify-center text-center relative overflow-hidden">
        <Star size={120} className="absolute -right-10 -bottom-10 text-gray-50 opacity-50" />
        <div className="z-10 w-full font-bold">
          {currentQ.questionNode ? currentQ.questionNode : (
            <h2 className="text-2xl text-gray-800 leading-relaxed">{currentQ.questionStr}</h2>
          )}
        </div>
      </div>

      <div className="space-y-3 flex-1">
        {currentQ.options.map((option, idx) => {
          let btnClass = "bg-white border-2 border-gray-200 text-gray-700 hover:border-blue-400 hover:bg-blue-50";
          let icon = null;

          if (selectedAnswer) {
             if (option === currentQ.answer) {
               btnClass = "bg-emerald-100 border-2 border-emerald-500 text-emerald-800";
               icon = <CheckCircle2 className="text-emerald-500" size={20} />;
             } else if (option === selectedAnswer && !isCorrect) {
               btnClass = "bg-rose-100 border-2 border-rose-500 text-rose-800";
               icon = <XCircle className="text-rose-500" size={20} />;
             } else {
               btnClass = "bg-gray-50 border-2 border-gray-200 text-gray-400 opacity-50";
             }
          }

          return (
            <button
              key={idx}
              disabled={selectedAnswer !== null}
              onClick={() => handleAnswer(option)}
              className={`w-full p-4 rounded-xl text-left font-medium transition-all flex items-center justify-between ${btnClass}`}
            >
              <span>{option}</span>
              {icon}
            </button>
          );
        })}
      </div>
    </div>
  );
}
