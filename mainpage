// --- メインコンポーネント ---

export default function App() {
  const [currentView, setCurrentView] = useState('home'); // 'home', 'vocab', 'phrases', 'quiz'
  
  // テキスト読み上げ関数
  const speakText = useCallback((text) => {
    if ('speechSynthesis' in window) {
      window.speechSynthesis.cancel();
      const utterance = new SpeechSynthesisUtterance(text);
      utterance.lang = 'en-US';
      utterance.rate = 0.9;
      window.speechSynthesis.speak(utterance);
    } else {
      alert('お使いのブラウザは音声読み上げに対応していません。');
    }
  }, []);

  const renderHeader = (title, showBack = true) => (
    <div className="bg-blue-600 text-white p-4 flex items-center shadow-md sticky top-0 z-10">
      {showBack && (
        <button onClick={() => setCurrentView('home')} className="mr-3 hover:bg-blue-700 p-1 rounded-full transition-colors">
          <ArrowLeft size={24} />
        </button>
      )}
      <h1 className="text-xl font-bold flex-1 text-center pr-8">{title}</h1>
    </div>
  );

  return (
    <div className="min-h-screen bg-slate-100 flex justify-center">
      <div className="w-full max-w-md bg-white shadow-xl min-h-screen relative overflow-hidden flex flex-col">
        {currentView === 'home' && <HomeView setView={setCurrentView} />}
        {currentView === 'vocab' && (
          <>
            {renderHeader('単語帳 (Vocabulary)')}
            <VocabView speak={speakText} />
          </>
        )}
        {currentView === 'phrases' && (
          <>
            {renderHeader('フレーズ集 (Phrases)')}
            <PhraseView speak={speakText} />
          </>
        )}
        {currentView === 'quiz' && (
          <>
            {renderHeader('クイズに挑戦！')}
            <QuizView setView={setCurrentView} />
          </>
        )}
      </div>
    </div>
  );
}

